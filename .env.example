# ═══════════════════════════════════════════════════════════════
# maligeeAi Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains secrets!

# ═══════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=maligeeai

# ═══════════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2025
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# ═══════════════════════════════════════════════════════════════
# LLM INTEGRATION (Emergent AI)
# ═══════════════════════════════════════════════════════════════
EMERGENT_LLM_KEY=your-emergent-llm-api-key-here

# ═══════════════════════════════════════════════════════════════
# PUBLIC URLS (web + AppCreator24 / appmaker24)
# ═══════════════════════════════════════════════════════════════
# HTTPS URL where the React frontend is hosted (Vercel, etc.)
PUBLIC_WEB_URL=https://your-app.vercel.app
# HTTPS URL of this API (no /api suffix)
PUBLIC_API_URL=https://your-api.example.com
# Published AppCreator24 Android app link after you publish
APPCREATOR24_APP_URL=https://www.appcreator24.com/appXXXXXXXX

# ═══════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Comma-separated origins — include your Vercel URL
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ═══════════════════════════════════════════════════════════════
# STRIPE CONFIGURATION (For Future Implementation)
# ═══════════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ENVIRONMENT=development
# LOG_LEVEL=INFO
