# ═══════════════════════════════════════════════════════════════
# maligeeAi Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains secrets!

# ═══════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=maligeeai

# ═══════════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════════
# Secret key for signing JWT tokens - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2025

# JWT algorithm for token signing (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiry in hours (default: 72)
JWT_EXPIRY_HOURS=72

# ═══════════════════════════════════════════════════════════════
# LLM INTEGRATION (Emergent AI)
# ═══════════════════════════════════════════════════════════════
# API key for Emergent LLM service
# Get this from: https://emergent.sh
EMERGENT_LLM_KEY=your-emergent-llm-api-key-here

# ═══════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins
# Use "*" for development (NOT recommended for production)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*

# ═══════════════════════════════════════════════════════════════
# STRIPE CONFIGURATION (For Future Implementation)
# ═══════════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ═══════════════════════════════════════════════════════════════
# APPLICATION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════
# Environment: development, staging, production
# ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
